# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite
# txtpbfmt: wrap_strings_after_newlines

suite_name: "firebase_app_hosting_basics_activation"
timeout_seconds: 600

# Positive Cases (Should activate)
cases {
  name: "should_activate_nextjs_ssr"
  prompt: "I want to deploy a full-stack Next.js application using Server-Side Rendering (SSR) to Firebase."
  expectations: "The agent activated the 'firebase-app-hosting-basics' skill."
}

cases {
  name: "should_activate_angular"
  prompt: "How do I configure Firebase App Hosting to deploy my Angular web app?"
  expectations: "The agent activated the 'firebase-app-hosting-basics' skill."
}

cases {
  name: "should_activate_yaml_config"
  prompt: "Please help me set up the apphosting.yaml file for my backend environment variables."
  expectations: "The agent activated the 'firebase-app-hosting-basics' skill."
}

cases {
  name: "should_activate_json_block"
  prompt: "How do I write the apphosting block in my firebase.json config?"
  expectations: "The agent activated the 'firebase-app-hosting-basics' skill."
}

cases {
  name: "should_activate_secrets"
  prompt: "What command do I run to set up secrets like API keys safely in Firebase App Hosting?"
  expectations: "The agent activated the 'firebase-app-hosting-basics' skill."
}

cases {
  name: "should_activate_create_backend"
  prompt: "How do I create a new App Hosting backend using the Firebase CLI?"
