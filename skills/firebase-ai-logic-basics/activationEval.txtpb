# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite
# txtpbfmt: wrap_strings_after_newlines

suite_name: "firebase_ai_logic_basics_activation"
timeout_seconds: 600

# Positive Cases (Should activate)
cases {
  name: "should_activate_init_ailogic"
  prompt: "How do I initialize Firebase AI Logic in my project using the CLI?"
  expectations: "The agent activated the 'firebase-ai-logic-basics' skill."
}

cases {
  name: "should_activate_gemini_api"
