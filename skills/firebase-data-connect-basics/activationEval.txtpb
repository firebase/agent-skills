# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite
# txtpbfmt: wrap_strings_after_newlines

suite_name: "firebase_data_connect_basics_activation"
timeout_seconds: 600

# Positive Cases (Should activate)
cases {
  name: "should_activate_init_dataconnect"
  prompt: "How do I initialize Firebase Data Connect in my project using the CLI?"
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_schema_gql"
  prompt: "Help me write a GraphQL schema with table directives for a relational movie database in schema.gql."
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_postgres_relation"
  prompt: "How do I model a many-to-many relationship between Users and Movies using the @ref directive in Data Connect?"
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_queries_gql"
  prompt: "Write a GraphQL query in queries.gql to search for movies with filters on rating and genre."
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_mutations_upsert"
  prompt: "Explain how to write an upsert mutation in Data Connect to insert or update user profiles."
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_sdk_generate"
  prompt: "What is the command to generate a type-safe Swift SDK from my GraphQL schemas in connector.yaml?"
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_vector_search"
  prompt: "How do I implement vector semantic search with Data Connect and PostgreSQL?"
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_transaction"
  prompt: "How do I group multiple GraphQL operations into an atomic transaction with the @transaction directive?"
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_native_sql"
  prompt: "How do I run a raw SQL window function in Firebase SQL Connect using Native SQL?"
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

cases {
  name: "should_activate_realtime"
  prompt: "How do I configure real-time subscriptions in Data Connect using the @refresh directive?"
  expectations: "The agent activated the 'firebase-data-connect' skill."
}

