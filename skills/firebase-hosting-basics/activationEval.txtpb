# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite
# txtpbfmt: wrap_strings_after_newlines

suite_name: "firebase_hosting_basics_activation"
timeout_seconds: 600

# Positive Cases (Should activate)
cases {
  name: "should_activate_deploy"
  prompt: "How do I deploy my static website to Firebase Hosting?"
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_custom_domain"
  prompt: "Please show me how to configure my custom domain name for my Firebase Hosting site."
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_redirects"
  prompt: "How do I set up a redirects configuration in firebase.json to redirect /old to /new?"
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_headers"
  prompt: "I need to add headers to my static files to enable CORS on Firebase Hosting."
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_rewrites"
  prompt: "Please configure rewrites in firebase.json to route all traffic to my single-page app's index.html."
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_deploy_target"
  prompt: "What command do I run to deploy only my hosting site using the Firebase CLI?"
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_previews"
  prompt: "How do I set up preview channels to test my site updates before releasing them to production?"
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_preview_expiry"
  prompt: "Please configure my Firebase Hosting project to clean up old previews after 7 days."
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_multisite"
  prompt: "How do I deploy multiple sites (multi-site hosting) in the same Firebase project?"
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_activate_json_config"
  prompt: "Write a basic hosting configuration block for my firebase.json file."
  expectations: "The agent activated the 'firebase-hosting-basics' skill."
}

# Negative Cases (Should NOT activate)
cases {
  name: "should_not_activate_auth"
  prompt: "How do I configure Firebase Authentication for email and password login?"
  expectations: "The agent did not activate the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_not_activate_firestore"
  prompt: "Help me write a Firestore query to get users who are active."
  expectations: "The agent did not activate the 'firebase-hosting-basics' skill."
}

cases {
  name: "should_not_activate_app_hosting"
