# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite
# txtpbfmt: wrap_strings_after_newlines

suite_name: "firebase_remote_config_basics_activation"
timeout_seconds: 600

# Positive Cases (Should activate)
cases {
  name: "should_activate_template_get"
  prompt: "How do I download my current Firebase Remote Config template as a JSON file using the CLI?"
  expectations: "The agent activated the 'firebase-remote-config-basics' skill."
}

cases {
  name: "should_activate_deploy_remoteconfig"
  prompt: "Show me how to deploy my local remote_config.json changes to Firebase."
  expectations: "The agent activated the 'firebase-remote-config-basics' skill."
}

cases {
  name: "should_activate_android_sdk_setup"
  prompt: "How do I initialize Remote Config in my Android app code and fetch values?"
  expectations: "The agent activated the 'firebase-remote-config-basics' skill."
}

cases {
  name: "should_activate_ios_sdk_setup"
